# Copy this file to .env and replace every placeholder value.
# Do NOT commit .env. Real secrets belong only in your local .env or your secret store.

# Postgres connection used by the API and worker (async driver).
DATABASE_URL=postgresql+asyncpg://crashlens:REPLACE_WITH_DB_PASSWORD@postgres:5432/crashlens

# Credentials used by the postgres container to initialise the database.
# Keep POSTGRES_PASSWORD in sync with the password in DATABASE_URL above.
POSTGRES_USER=crashlens
POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD
POSTGRES_DB=crashlens

# Redis connection used for the job queue and rate limiting.
REDIS_URL=redis://redis:6379/0

# Application secret key. Generate a long random value, for example:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Deployment environment label (development | staging | production).
ENVIRONMENT=development

# --- Email alerts (OPTIONAL) -------------------------------------------------
# Email alerting is OFF unless BOTH SMTP_HOST and SMTP_FROM are set. When unset,
# the alert engine logs a single warning once per process and skips email
# channels; Slack and generic webhook alerts still work without any of these.
# SMTP_USERNAME / SMTP_PASSWORD may be omitted for a relay that needs no auth.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=alerts@example.com
SMTP_STARTTLS=true

# Optional public base URL of this dashboard (no trailing slash). When set, it is
# prefixed to the issue link inside alerts to make them clickable, for example:
#   https://crashlens.example.com
# When unset, alerts carry the relative /org/.../issues/... path only.
PUBLIC_BASE_URL=
