# Copy this file to .env and replace every placeholder value.
# Do NOT commit .env. Real secrets belong only in your local .env or your secret store.

# --- Database ----------------------------------------------------------------
# TWO Postgres users, by design, so tenant isolation (PostgreSQL Row Level
# Security) is actually enforced at runtime:
#
#   * POSTGRES_USER  - the SUPERUSER the postgres container creates. It OWNS the
#                      schema and runs MIGRATIONS (DDL needs ownership). The
#                      application NEVER connects as this user, because
#                      superusers BYPASS Row Level Security, which would silently
#                      disable tenant isolation.
#   * crashlens_login - the NON-superuser RUNTIME user the API and worker connect
#                      as. RLS only constrains non-superusers, so running the app
#                      as this role is what makes tenant isolation real. The
#                      postgres container creates it at first startup via
#                      deploy/postgres-init/01-app-user.sh.

# Runtime connection used by the API and worker (async driver). User is
# crashlens_login (NON-superuser) on purpose - do NOT change it to the superuser.
DATABASE_URL=postgresql+asyncpg://crashlens_login:REPLACE_WITH_APP_DB_PASSWORD@postgres:5432/crashlens

# Password for the crashlens_login runtime role. The postgres container's init
# script (deploy/postgres-init/01-app-user.sh) creates crashlens_login with this
# value at first startup; keep it in sync with the password in DATABASE_URL.
CRASHLENS_DB_APP_PASSWORD=REPLACE_WITH_APP_DB_PASSWORD

# Superuser credentials the postgres container initialises the database with.
# This user owns the schema and runs migrations only.
POSTGRES_USER=crashlens
POSTGRES_PASSWORD=REPLACE_WITH_SUPERUSER_DB_PASSWORD
POSTGRES_DB=crashlens

# Connection used ONLY to run migrations, as the schema-owning superuser (Alembic
# needs DDL ownership). Keep the user/password in sync with POSTGRES_USER /
# POSTGRES_PASSWORD. Run migrations with:
#   docker compose run --rm -e DATABASE_URL=${MIGRATIONS_DATABASE_URL} api alembic upgrade head
MIGRATIONS_DATABASE_URL=postgresql+asyncpg://crashlens:REPLACE_WITH_SUPERUSER_DB_PASSWORD@postgres:5432/crashlens

# Redis connection used for the job queue and rate limiting.
REDIS_URL=redis://redis:6379/0

# Application secret key. Generate a long random value, for example:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Deployment environment label (development | staging | production).
ENVIRONMENT=development

# --- Email alerts (OPTIONAL) -------------------------------------------------
# Email alerting is OFF unless BOTH SMTP_HOST and SMTP_FROM are set. When unset,
# the alert engine logs a single warning once per process and skips email
# channels; Slack and generic webhook alerts still work without any of these.
# SMTP_USERNAME / SMTP_PASSWORD may be omitted for a relay that needs no auth.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=alerts@example.com
SMTP_STARTTLS=true

# Optional public base URL of this dashboard (no trailing slash). When set, it is
# prefixed to the issue link inside alerts to make them clickable, for example:
#   https://crashlens.example.com
# When unset, alerts carry the relative /org/.../issues/... path only.
PUBLIC_BASE_URL=
