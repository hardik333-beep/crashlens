# Crashlens reverse proxy.
#
# Set CRASHLENS_SITE_ADDRESS in your environment to your public hostname (for
# example crashlens.example.com) to get automatic HTTPS. It defaults to :80 for
# local development, which serves plain HTTP.
{$CRASHLENS_SITE_ADDRESS::80} {
	# Serve the compiled dashboard as static files.
	root * /srv/dashboard
	encode gzip

	# Source map uploads need a much larger body than the ingest hot path, so
	# they are matched FIRST (before the generic /api handler below) and given
	# their own 25MB cap. The application additionally enforces a per-file 20MB
	# cap while streaming (see app/routes/sourcemaps.py); this edge cap bounds the
	# whole multipart request. The /api prefix is stripped manually here (this
	# block uses `handle`, not `handle_path`, because the matcher is a regexp), so
	# POST /api/orgs/{org}/projects/{project}/sourcemaps reaches the application as
	# /orgs/{org}/projects/{project}/sourcemaps.
	@sourcemaps path_regexp ^/api/orgs/[^/]+/projects/[^/]+/sourcemaps(/.*)?$
	handle @sourcemaps {
		request_body {
			max_size 25MB
		}
		uri strip_prefix /api
		reverse_proxy api:8000
	}

	# API traffic is reverse-proxied to the FastAPI service. handle_path strips
	# the /api prefix, so /api/health reaches the application as /health. The
	# ingest route (and everything else under /api except source map uploads
	# above) keeps the small 250KB body cap so a large payload is rejected at the
	# edge before it reaches the application.
	handle_path /api/* {
		request_body {
			max_size 250KB
		}
		reverse_proxy api:8000
	}

	# Everything else is the single-page dashboard. Unknown paths fall back to
	# index.html so client-side routing works.
	handle {
		try_files {path} /index.html
		file_server
	}
}
